# ==========================================
# 环境配置模板
# 复制此文件为 .env.development 或 .env.production
# ==========================================

# 环境标识
NODE_ENV=development

# ==========================================
# Worker 配置
# ==========================================
WORKER_NAME=worker_01

# ==========================================
# 任务服务器配置
# ==========================================
TASK_SERVER_URL=http://127.0.0.1:11008

# ==========================================
# 📦 资源存储配置
# ==========================================
# 是否开启保存资源到云存储 (true/false)
ENABLE_CLOUD_STORAGE=false
# 存储服务类型: cos | oss | qiniu
STORAGE_TYPE=cos

# ==========================================
# 腾讯云 COS 配置
# ==========================================
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_REGION=ap-hongkong
COS_BUCKET=your_bucket_name

# ==========================================
# 阿里云 OSS 配置
# ==========================================
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your_bucket_name
OSS_PREFIX=seedance/

# ==========================================
# 七牛云配置
# ==========================================
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=your_bucket_name
# 存储区域: z0华东 z1华北 z2华南 na0北美 as0东南亚
QINIU_ZONE=z0
# 七牛云绑定的域名 (用于生成访问URL)
QINIU_DOMAIN=https://your-domain.com
QINIU_PREFIX=seedance/

# ==========================================
# 浏览器配置
# ==========================================
# 是否无头模式运行 (true/false)
HEADLESS=false

# 最大并发任务数
MAX_CONCURRENT_TASKS=10

# 生成超时时间 (毫秒)
GEN_TIMEOUT=3600000
